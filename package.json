{
  "name": "leadforge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^1.11.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
