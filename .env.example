# General Config
NODE_ENV=development
PORT=3001

# Database (External TiDB config should be placed here)
DATABASE_URL="mysql://root:password@host.docker.internal:4000/leadforge"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET=super_secret_jwt_key_for_development
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super_secret_refresh_key_for_development
JWT_REFRESH_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000
